# =================================================================
# SECURITY CONFIGURATION - Environment Variables
# =================================================================
# 
# This file shows all required and optional environment variables
# for secure deployment of the Privacy Exposure Checker.
# 
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env
# 2. Fill in all required values (marked with *REQUIRED*)
# 3. Generate secure random values for SECRET_KEY and ADMIN_API_KEY
# 4. Never commit .env to version control!
# 
# =================================================================

# -----------------------------------------------------------------
# FLASK CONFIGURATION
# -----------------------------------------------------------------

# *REQUIRED* Secret key for Flask sessions (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-secret-key-here

# Environment: development or production
FLASK_ENV=production

# Debug mode: true or false (ALWAYS false in production!)
FLASK_DEBUG=false

# -----------------------------------------------------------------
# SECURITY - API AUTHENTICATION
# -----------------------------------------------------------------

# *REQUIRED* API key for admin endpoints (generate with: python -c "import secrets; print(secrets.token_hex(32))")
ADMIN_API_KEY=your-admin-api-key-here

# -----------------------------------------------------------------
# SECURITY - CORS
# -----------------------------------------------------------------

# Allowed origins for CORS (comma-separated)
# Example: https://yourdomain.com,https://api.yourdomain.com
ALLOWED_ORIGINS=http://localhost:5000

# -----------------------------------------------------------------
# SECURITY - RATE LIMITING
# -----------------------------------------------------------------

# Rate limit storage URI
# Options:
#   - memory:// (default, not persistent, ok for single server)
#   - redis://localhost:6379 (recommended for production)
#   - memcached://localhost:11211
RATE_LIMIT_STORAGE_URI=memory://

# -----------------------------------------------------------------
# DATABASE CONFIGURATION
# -----------------------------------------------------------------

# Database type: sqlite or postgresql
DB_TYPE=sqlite

# SQLite path (if using SQLite)
SQLITE_DB_PATH=face_recognition.db

# PostgreSQL configuration (if using PostgreSQL)
# *REQUIRED* if DB_TYPE=postgresql
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=face_recognition
POSTGRES_USER=your-postgres-user
POSTGRES_PASSWORD=your-secure-postgres-password

# -----------------------------------------------------------------
# FACE DETECTION CONFIGURATION
# -----------------------------------------------------------------

# Minimum face detection confidence (0.0 - 1.0)
MIN_FACE_CONFIDENCE=0.90

# Minimum similarity threshold for face matches (0.0 - 1.0)
MIN_SIMILARITY_THRESHOLD=0.70

# Face clustering threshold (0.0 - 1.0)
FACE_MATCH_THRESHOLD=0.6

# Minimum cluster size
MIN_CLUSTER_SIZE=2

# -----------------------------------------------------------------
# FAISS INDEX CONFIGURATION
# -----------------------------------------------------------------

# FAISS index file path
FAISS_INDEX_PATH=faiss_index.bin

# FAISS index type: flat (exact) or ivf (approximate)
FAISS_INDEX_TYPE=flat

# IVF clusters (if using IVF index)
FAISS_IVF_CLUSTERS=100

# Distance metric: L2 (Euclidean) or IP (cosine similarity)
FAISS_METRIC=L2

# -----------------------------------------------------------------
# WEB SCRAPING CONFIGURATION
# -----------------------------------------------------------------

# Maximum concurrent download workers
MAX_WORKERS=5

# Rate limit between requests to same domain (seconds)
RATE_LIMIT_SECONDS=0.2

# Page load wait time (seconds)
PAGE_LOAD_WAIT_SECONDS=5

# Run browser in headless mode (true/false)
HEADLESS_BROWSER=true

# -----------------------------------------------------------------
# LOGGING CONFIGURATION
# -----------------------------------------------------------------

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
